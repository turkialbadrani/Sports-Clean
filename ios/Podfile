platform :ios, '14.0'  # رفعت الحد الأدنى من 13.0 إلى 14.0

# حمّل podhelper.rb من مجلد Flutter SDK مباشرة
flutter_root = ENV['FLUTTER_ROOT']
raise 'FLUTTER_ROOT is not set' if flutter_root.nil? || flutter_root.empty?

begin
  require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper.rb'), flutter_root)
rescue LoadError
  # بعض إصدارات Flutter تسميه بدون .rb
  require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)
end

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  # إعدادات Flutter الإضافية
  flutter_additional_ios_build_settings(installer)

  # ثبّت الـ deployment target = 14.0 على كل بود
  installer.pods_project.targets.each do |t|
    t.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
    end
  end
end
